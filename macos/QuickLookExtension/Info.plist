<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SSHVault Quick Look</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>de.kiefer_networks.SSHVault.QuickLookExtension</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>XPC!</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>

	<key>NSExtension</key>
	<dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.quicklook.preview</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).PreviewProvider</string>
		<key>NSExtensionAttributes</key>
		<dict>
			<key>QLSupportedContentTypes</key>
			<array>
				<string>de.kiefer-networks.sshvault.public-key</string>
				<string>de.kiefer-networks.sshvault.pem-key</string>
				<string>de.kiefer-networks.sshvault.ppk-key</string>
			</array>
			<key>QLSupportsSearchableItems</key>
			<false/>
		</dict>
	</dict>

	<!--
	  We re-declare the imported UTIs here so the extension binary can be
	  loaded standalone (e.g. when the user has not yet launched the host
	  app once after install). The host app's Info.plist exports the same
	  identifiers via UTExportedTypeDeclarations.
	-->
	<key>UTImportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>de.kiefer-networks.sshvault.public-key</string>
			<key>UTTypeDescription</key>
			<string>SSH Public Key</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.text</string>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>pub</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-ssh-pub</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>de.kiefer-networks.sshvault.pem-key</string>
			<key>UTTypeDescription</key>
			<string>PEM-encoded Private Key</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.text</string>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>pem</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-pem-file</string>
				</array>
			</dict>
		</dict>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>de.kiefer-networks.sshvault.ppk-key</string>
			<key>UTTypeDescription</key>
			<string>PuTTY Private Key</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.text</string>
				<string>public.plain-text</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>ppk</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-putty-private-key</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
