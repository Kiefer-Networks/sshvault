<?xml version="1.0" encoding="utf-8"?>
<!--
    Static App Shortcuts for SSHVault.

    These appear when the user long-presses the launcher icon. Each shortcut
    encodes its action as a `sshvault://` deep-link URI on a VIEW intent
    targeted at MainActivity. Routing then happens on the Dart side via the
    same logic as external `sshvault://` URLs.

    The dynamic favorite shortcuts (`sshvault://host/<id>`) are pushed at
    runtime by `MainActivity.kt` over the
    `de.kiefer_networks.sshvault/shortcuts` method channel — they live next
    to these static entries up to the platform-imposed maximum of 5.
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:shortcutId="quick_connect"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_connect"
        android:shortcutShortLabel="@string/shortcut_quick_connect_short"
        android:shortcutLongLabel="@string/shortcut_quick_connect_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="sshvault://quick-connect"
            android:targetPackage="de.kiefer_networks.sshvault"
            android:targetClass="de.kiefer_networks.sshvault.MainActivity"/>
        <categories android:name="android.shortcut.conversation"/>
    </shortcut>

    <shortcut
        android:shortcutId="new_host"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_add"
        android:shortcutShortLabel="@string/shortcut_new_host_short"
        android:shortcutLongLabel="@string/shortcut_new_host_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="sshvault://new-host"
            android:targetPackage="de.kiefer_networks.sshvault"
            android:targetClass="de.kiefer_networks.sshvault.MainActivity"/>
        <categories android:name="android.shortcut.conversation"/>
    </shortcut>

    <shortcut
        android:shortcutId="last_session"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_history"
        android:shortcutShortLabel="@string/shortcut_last_session_short"
        android:shortcutLongLabel="@string/shortcut_last_session_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:data="sshvault://reopen-last"
            android:targetPackage="de.kiefer_networks.sshvault"
            android:targetClass="de.kiefer_networks.sshvault.MainActivity"/>
        <categories android:name="android.shortcut.conversation"/>
    </shortcut>
</shortcuts>
